[alias]
	a = "add"
	af = "!git add $(git ls-files -m -o --exclude-standard | sk -m)"
	b = "branch"
	br = "branch"
	c = "commit"
	ca = "commit --amend"
	cm = "commit -m"
	co = "checkout"
	d = "diff"
	ds = "diff --staged"
	edit-unmerged = "!f() { git ls-files --unmerged | cut -f2 | sort -u ; }; hx `f`"
	essa = "push --force"
	fuck = "commit --amend -m"
	graph = "log --all --decorate --graph --oneline"
	hist = "log --pretty=format:\"%Cgreen%h %Creset%cd %Cblue[%cn] %Creset%s%C(yellow)%d%C(reset)\" --graph --date=relative --decorate --all"
	l = "log"
	llog = "log --graph --name-status --pretty=format:\"%C(red)%h %C(reset)(%cd) %C(green)%an %Creset%s %C(yellow)%d%Creset\" --date=relative"
	oops = "checkout --"
	p = "push"
	pf = "push --force-with-lease"
	pl = "!git pull origin $(git rev-parse --abbrev-ref HEAD)"
	prettylog = "log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
	ps = "!git push origin $(git rev-parse --abbrev-ref HEAD)"
	r = "rebase"
	s = "status --short"
	sha = "rev-parse origin/main"
	sm = "switch main"
	ss = "status"
	st = "status"

[blame]
	date = "relative"

[branch]
	autosetupmerge = true

[color]
	ui = true

[core]
	editor = "nvim"
	pager = "/nix/store/yy3qkcm0mj96i9s4yp9hy7s5irriy0mq-delta-0.18.2/bin/delta"
	whitespace = "fix,-indent-with-non-tab,trailing-space,cr-at-eol"

[credential "https://gist.github.com"]
	helper = "/nix/store/a42dil5xrgf74ir5nnryhyg4v0ymkpi0-gh-2.69.0/bin/gh auth git-credential"

[credential "https://github.com"]
	helper = "/nix/store/a42dil5xrgf74ir5nnryhyg4v0ymkpi0-gh-2.69.0/bin/gh auth git-credential"

[delta]
	enable = true
	features = "decorations line-numbers"
	hyprlinks = true
	navigate = true
	syntax-theme = "none"
	whitespace-error-style = "22 reverse"

[delta "decorations"]
	commit-decoration-style = "bold yellow box ul"
	file-decoration-style = "none"
	file-style = "bold yellow ul"
	hunk-decoration-style = "bold blue ul"
	hunk-header-style = "omit"

[delta "line-numbers"]
	line-numbers = true
	line-numbers-left-format = ""
	line-numbers-left-style = ""
	line-numbers-minus-style = "brightblack"
	line-numbers-plus-style = "brightblack"
	line-numbers-right-format = "{np:>4}│"
	line-numbers-right-style = "brightblack"
	line-numbers-zero-style = "brightblack"

[delta "options"]
	navigate = true

[diff]
	tool = "meld"

[gpg]
	format = "openpgp"

[gpg "openpgp"]
	program = "/nix/store/pggww1d2pg24fcg5v36xn63n53vanyyi-gnupg-2.4.7/bin/gpg"

[init]
	defaultBranch = "main"

[interactive]
	diffFilter = "/nix/store/yy3qkcm0mj96i9s4yp9hy7s5irriy0mq-delta-0.18.2/bin/delta --color-only"

[merge]
	stat = "true"

[pull]
	ff = "only"
	rebase = true

[push]
	autoSetupRemote = true
	default = "tracking"

[rebase]
	autoSqaush = true
	autoStash = true
	updateRefs = true

[rerere]
	autoupdate = true
	enabled = true

[user]
	email = "wborbajr@gmail.com"
	name = "Waldir Borba Junior"

[web]
	browser = "google-chrome-stable"
