# i3 config file (v4)
# Clean and organized configuration with Catppuccin theme

set $mod Mod4

# ==================== SCREENSHOT ====================
bindsym Print exec --no-startup-id flameshot gui
bindsym $mod+Print --release exec --no-startup-id flameshot screen
bindsym $mod+F4 exec --no-startup-id flameshot gui

# ==================== APPEARANCE ====================
font pango:FiraCode Nerd Font 10

# Flat borders, no title bars
for_window [class="^.*"] border pixel 2

# Allow dragging windows by title bar or with $mod
tiling_drag modifier titlebar

# ==================== AUTOSTART ====================
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id lxpolkit
exec --no-startup-id picom
exec --no-startup-id nm-applet
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# ==================== VOLUME & BRIGHTNESS ====================
set $refresh_i3status killall -SIGUSR1 i3status

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl s 10%+ && $refresh_i3status
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl s 10%- && $refresh_i3status

# ==================== BASIC MOVEMENT ====================
floating_modifier $mod

bindsym $mod+Return exec i3-sensible-terminal
bindsym $mod+Shift+q kill

# Focus movement
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Monitor navigation
bindsym $mod+o move workspace to output right
bindsym $mod+Shift+j focus output left
bindsym $mod+Shift+k focus output right

# ==================== WINDOW LAYOUT ====================
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

bindsym $mod+a focus parent

# ==================== WORKSPACES ====================
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# ==================== POWER MENU ====================
bindsym $mod+Shift+e exec --no-startup-id "i3-nagbar -t warning -m 'Power Menu' \
    -B '  Logout' 'i3-msg exit' \
    -B '  Hibernate' 'systemctl hibernate' \
    -B '  Suspend' 'systemctl suspend' \
    -B '  Reboot' 'systemctl reboot' \
    -B '  Shutdown' 'systemctl poweroff'"

# ==================== SESSION CONTROL ====================
# Missing from the original config — present in the reference config.
# Reload just re-reads this file (fast, no visual disruption).
# Restart re-execs i3 in place (preserves layout/session), useful after
# upgrading i3 or if something gets into a weird state.
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# ==================== LOCK SCREEN ====================
# Missing from the original config. xss-lock already locks on sleep/idle
# (see AUTOSTART), but this adds a manual "lock right now" key using the
# same wallpaper set below.
bindsym $mod+Escape exec --no-startup-id i3lock -i ~/Pictures/wallpaper.png

# ==================== RESIZE MODE ====================
mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# ==================== LAUNCHERS ====================
bindsym $mod+d exec --no-startup-id "rofi -combi-modi window,drun -show combi -modi combi -show-icons"
bindsym $mod+g exec --no-startup-id rofi -show window

bindsym F1 exec $HOME/.config/emacs/bin/doom run

# ---- Optional: direct app launchers (present in reference config) ----
# Not enabled by default since app choice/terminal is personal and the
# reference paths (alacritty, specific scripts) may not match your setup.
# Uncomment and adjust binaries/paths as needed.
# bindsym $mod+z exec firefox
# bindsym $mod+n exec chromium
# bindsym $mod+m exec vlc
# bindsym $mod+x exec i3-sensible-terminal -e ranger
# bindsym $mod+c exec i3-sensible-terminal -e tmux
# bindsym $mod+i exec --no-startup-id ~/scripts/wifi.sh

# ==================== MONITOR SETUP ====================
workspace 1 output eDP-1
workspace 2 output DP-4

exec_always xrandr --output DP-4 --mode 2560x1440 --scale 0.8x0.8 --rate 59.97 --right-of eDP-1 --rotate normal --output eDP-1 --auto --scale 0.6x0.6 --pos 0x0 --primary

# ==================== WALLPAPER ====================
exec_always --no-startup-id feh --bg-max --no-fehbg ~/Pictures/wallpaper.png
bindsym $mod+Shift+w exec --no-startup-id "feh --bg-max --no-fehbg ~/Pictures/wallpaper.png"

# ==================== BAR CONFIG ====================
# Missing from the original config: toggle bar visibility.
bindsym $mod+b bar mode toggle

bar {
    position bottom
    tray_output primary
    status_command i3status

    colors {
        background #1e1e2e
        statusline #cdd6f4
        separator #45475a

        focused_workspace  #45475a #45475a #cdd6f4
        active_workspace   #1e1e2e #313244 #cdd6f4
        inactive_workspace #1e1e2e #1e1e2e #a6adc8
        urgent_workspace   #f38ba8 #f38ba8 #1e1e2e
        binding_mode       #f38ba8 #f38ba8 #1e1e2e
    }
}

# ==================== CLIENT COLORS (Catppuccin Mocha) ====================
client.focused          #cba6f7 #cba6f7 #1e1e2e #cba6f7 #cba6f7
client.focused_inactive #585b70 #313244 #cdd6f4 #45475a #45475a
client.unfocused        #11111b #1e1e2e #a6adc8 #11111b #11111b
client.urgent           #f38ba8 #f38ba8 #1e1e2e #f38ba8 #f38ba8
client.placeholder      #1e1e2e #1e1e2e #cdd6f4 #1e1e2e #1e1e2e
client.background       #1e1e2e
