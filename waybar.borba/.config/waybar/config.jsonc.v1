{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,

    // "modules-left": ["niri/workspaces", "niri/window"],
    // "modules-center": ["clock"],
    // "modules-right": ["bluetooth", "network", "battery", "pulseaudio", "tray"],

    // "modules-left": ["niri/workspaces", "niri/window"],
    // "modules-center": ["clock"],
    // "modules-right": ["idle_inhibitor", "cpu", "memory", "temperature", "backlight", "battery", "bluetooth", "network", "pulseaudio", "tray"],

    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": ["clock"],
    "modules-right": ["idle_inhibitor", "cpu", "memory", "custom/notification", "backlight", "battery", "bluetooth", "network", "pulseaudio", "tray"],


      "custom/notification": {
        "tooltip": false,
        "format": "{icon} {text}",
        "format-icons": {
            "notification": "َ±…«",
            "none": "َ°‚œ",
            "dnd-notification": "َ°‚ ",
            "dnd-none": "َ°ھ“",
            "inhibited-notification": "َ°‚›",
            "inhibited-none": "َ°ھ‘",
            "dnd-inhibited-notification": "َ°‚›",
            "dnd-inhibited-none": "َ°ھ‘"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "clock": {
        "format": "{:%a %d %b  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

  "cpu": {
        "format": "َ°چ› {usage}%",
        "interval": 5
    },

    "memory": {
        "format": "َ°کڑ {percentage}%",
        "interval": 10
    },

    "temperature": {
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": ["ï‹‰", "ï‹ˆ", "َ°”„"],
        "critical-threshold": 80,
        "interval": 10
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["َ°ƒڑ", "َ°ƒ›", "َ°ƒœ", "َ°ƒ‌", "َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

  "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "âک•",
            "deactivated": "َ°¤„"
        },
        "tooltip-format-activated": "Nأ£o dormir ativado",
        "tooltip-format-deactivated": "Nأ£o dormir desativado"
    },

    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "ï†’",
            "default": "ï„‘"
        },
        "all-outputs": false
    },

    "niri/window": {
        "format": "{}",
        "max-length": 60,
        "rewrite": {
            "(.*) - Mozilla Firefox": "ًںŒچ $1",
            "(.*) - Brave": "ًںŒچ $1"
        }
    },

    "battery": {
        "bat": "BAT0",          // â†گ verifique com: ls /sys/class/power_supply/
        "adapter": "ADP0",
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "network": {
        "format-wifi": "ï‡« {essid} ({signalStrength}%)",
        "format-ethernet": "َ°ˆ€ {ipaddr}",
        "format-disconnected": "َ°¤® Desconectado",
        "tooltip-format": "{ifname} â€¢ {ipaddr}",
        "on-click": "nm-connection-editor"
    },

  "bluetooth": {
    "format": "ïٹ” {status}",
    "format-disabled": "َ°‚²",
    "format-connected": "ïٹ” {num_connections}",
    "format-on": "ïٹ”",
    "tooltip-format": "{controller_alias}\n{controller_address}",
    "tooltip-format-connected": "{controller_alias}\n{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} {device_address}",
    "on-click": "blueman-manager"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں Mudo",
        "format-icons": ["ï€¦", "ï€§", "ï€¨"],
        "on-click": "pavucontrol"
    },

    "tray": {
        "spacing": 10
    }
}
