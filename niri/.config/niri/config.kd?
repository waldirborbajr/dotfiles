// ============================================================
// NIRI CONFIG - CLEAN & OPTIMIZED
// ============================================================

// Prefer server-side decorations when possible
prefer-no-csd

// ============================================================
// INPUT CONFIGURATION
// ============================================================
input {
    keyboard {
        // Delay before key repeat starts (ms)
        repeat-delay 200

        // Key repeat rate (keys per second)
        repeat-rate 35

        xkb {
            // Add layout/variant here if needed
        }

        // Enable NumLock on startup
        numlock
    }

    touchpad {
        // Enable tap to click
        tap

        // Disable touchpad while typing
        dwt

        // Natural scrolling (like macOS)
        natural-scroll

        // Disable touchpad when mouse is connected
        disabled-on-external-mouse

        // Optional tuning
        accel-speed 0.3
        scroll-method "two-finger"
    }

    mouse {
        // You can tune mouse acceleration here if needed
    }

    trackpoint {
        // Add configuration if you use TrackPoint
    }

    // Focus follows mouse improves workflow speed
    focus-follows-mouse max-scroll-amount="0%"
}

// ============================================================
// OUTPUT (MONITOR) CONFIGURATION
// ============================================================
output "eDP-1" {
    // Resolution and refresh rate
    mode "1920x1080@120.030"

    // HiDPI scaling
    scale 2

    // Rotation
    transform "normal"

    // Position in global layout
    position x=1280 y=0
}

// ============================================================
// LAYOUT CONFIGURATION
// ============================================================
layout {
    // Space between windows
    gaps 4

    // Disable forced centering
    center-focused-column "never"

    // Column width presets
    preset-column-widths {
        proportion 0.33
        proportion 0.5
        proportion 0.66
    }

    // Default column width
    default-column-width { proportion 0.5; }

    // Focus ring styling
    focus-ring {
        width 1.5
        active-color "#7fc8ff"
        inactive-color "#505050"
    }

    // Disable borders (clean look)
    border {
        off
    }

    // Subtle shadow for depth
    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }

    struts {}
}

// ============================================================
// STARTUP APPLICATIONS
// ============================================================

// QuickShell / launcher
spawn-sh-at-startup "qs"

// ============================================================
// GENERAL SETTINGS
// ============================================================

// Screenshot location
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// ============================================================
// ANIMATIONS
// ============================================================
animations {
    // Slightly faster animations for responsiveness
    slowdown 0.9
}

// ============================================================
// WINDOW RULES
// ============================================================

// Fix for WezTerm initial sizing bug
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Firefox Picture-in-Picture as floating
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// Open Firefox on workspace "c"
window-rule {
    match title="Firefox"
    open-on-workspace "c"
    open-maximized true
}

// Global rounded corners
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

// ============================================================
// WORKSPACES
// ============================================================
workspace "c" {}
workspace "b" {}
workspace "a" {}

// ============================================================
// DEBUG
// ============================================================
debug {
    honor-xdg-activation-with-invalid-serial
}

// ============================================================
// LAYER RULES
// ============================================================
layer-rule {
    match namespace="^noctalia-overview*"
    place-within-backdrop true
}

// ============================================================
// KEYBINDINGS
// ============================================================
binds {

    // Show hotkey help
    Mod+Shift+Slash { show-hotkey-overlay; }

    // Apps
    Mod+Return { spawn "alacritty"; }
    Mod+D { spawn "fuzzel"; }
    Super+Alt+L { spawn "swaylock"; }

    // Audio controls
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    // Brightness
    XF86MonBrightnessUp allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // Window management
    Mod+Q { close-window; }
    Mod+O { toggle-overview; }

    // Focus movement (vim-style included)
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }

    // Move windows
    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+J { move-window-down; }
    Mod+Ctrl+K { move-window-up; }
    Mod+Ctrl+L { move-column-right; }

    // Workspace navigation
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }

    // Layout controls
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }

    // Floating toggle
    Mod+V { toggle-window-floating; }

    // Resize
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    // Screenshot
    Mod+S { screenshot; }

    // Exit
    Mod+Shift+E { quit; }

    // Safety escape (disable inhibitors)
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
}
